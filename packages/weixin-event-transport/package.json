{
	"name": "cyrus-weixin-event-transport",
	"version": "0.1.0",
	"description": "WeChat/Weixin event transport using weixin-bot-sdk long-polling",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
